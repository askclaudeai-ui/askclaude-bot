    "reel_script": {
      "full_script": "First we import anthropic and create our client instance. This establishes the connection we need to access Claude. We call messages dot stream instead of create. This opens a live streaming connection that sends text as Claude generates it. We specify the model name, token limit, and message array. These are the exact same parameters as regular API calls. Inside the with block we loop through stream dot text stream. Each iteration receives the next chunk of text immediately. We print each chunk with flush equals true to show text instantly. Your users see responses appear word by word in real time.",
      "word_count": 102,
      "total_duration_s": 33.239999999999995,
      "full_code": [
        "import anthropic",
        "",
        "client = anthropic.Anthropic()",
        "",
        "with client.messages.stream(",
        "    model='claude-3-sonnet',",
        "    max_tokens=500,",
        "    messages=[{",
        "        'role': 'user',",
        "        'content': 'Hi Claude!'",
        "    }]",
        ") as stream:",
        "    for text in stream.text_stream:",
        "        print(text, end='',",
        "              flush=True)",
        "",
        "print('\\nDone streaming!')"
      ],
